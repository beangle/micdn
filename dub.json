{
  "name": "beangle-micdn",
  "version": "0.2.0",
  "description": "A minimal CDN.",
  "authors": [
    "chaostone"
  ],
  "license": "GPLv3",
  "toolchainRequirements": {
    "dub": ">=1.34.0",
    "frontend": ">=2.102.0",
    "ldc": ">=1.32.0"
  },
  "dependencies": {
    "dxml": "~>0.4.5",
    "dpq2": "~>1.2.3",
    "vibe-inet": "~>1.2.0",
    "vibe-d:web": "~>0.10.2",
    "vibe-http": "~>1.3.2",
    "vibe-stream:tls": "~>1.3.0",
    "vibe-d-postgresql": "~>3.2.1"
  },
  "configurations": [
    {
      "name": "executable",
      "targetType": "executable",
      "targetPath": "target",
      "targetName": "micdn"
    },
    {
      "name": "unittest",
      "sourcePaths": [
        "src",
        "test"
      ],
      "importPaths": [
        "src",
        "test"
      ],
      "dependencies": {
        "silly": "~>1.1.1"
      }
    }
  ],
  "subConfigurations": {
    "vibe-stream:tls": "notls"
  }
}
