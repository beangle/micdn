<?xml version="1.0" encoding="UTF-8"?>
<micdn xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:xi="http://www.w3.org/2001/XInclude"
  xsi:noNamespaceSchemaLocation="http://beangle.github.io/schema/micdn-1.0.0.xsd">

  <maven base="~/.m2/repository" endpoint="/maven">
    <remote url="https://maven.aliyun.com/repository/public" />
    <remote url="https://repo1.maven.org/maven2/" />
  </maven>

  <npmjs base="~/.npm-repo" endpoint="/npm">
    <remote url="https://registry.npmmirror.com" />
  </npmjs>

  <xi:include href="blob.xml" />

  <static endpoint="/static" base="~/.micdn/static">
    <bundle name="local">
      <dir location="${micdn.home}/local" />
    </bundle>
    <bundle name="AdminLTE">
      <jar gav="org.webjars:AdminLTE:3.2.0" />
    </bundle>
    <bundle name="bootstrap">
      <jar gav="org.webjars:bootstrap:4.6.1" />
      <npm package="bootstrap@5.3.8" />
      <npm package="bootstrap@5.3.7" />
    </bundle>
    <bundle name="bui">
      <jar gav="org.beangle.bundles:beangle-bundles-bui:0.6.7" />
    </bundle>
    <bundle name="echarts">
      <jar gav="org.webjars.bower:echarts:4.5.0"/>
      <jar gav="org.webjars.npm:echarts:5.3.1"/>
    </bundle>
  </static>

  <www>
    <doc location="/manual">
      <!-- <zip file="${micdn.home}/manual.zip" dir="manual" /> -->
      <npm package="@xurp/manual@0.0.2" />
    </doc>
  </www>

</micdn>
